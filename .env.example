# ============================================================
# BẢO MẬT: API Keys & Secrets
# Copy file này thành .env và điền giá trị thực
# KHÔNG BAO GIỜ commit file .env lên Git!
# ============================================================

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_USER=ufm_admin
POSTGRES_PASSWORD=ufm_secure_password_2026
POSTGRES_DB=ufm_admission_db
POSTGRES_PORT=5432

# --- App ---
APP_PORT=8000

# --- pgAdmin (optional) ---
PGADMIN_EMAIL=admin@ufm.edu.vn
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- Groq Cloud ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Google Gemini (Backup / Switch) ---
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- OpenAI Compatible (Backup / Switch) ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- OpenRouter (Backup / Switch) ---
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
